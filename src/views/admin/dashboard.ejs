<%- include("../partials/head") %>
<%- include("../partials/header") %>

<main class="min-h-screen bg-slate-50 px-4 pt-28">
  <section class="mx-auto max-w-7xl py-16 sm:px-6 lg:px-8">
    <% const createMemberValues = typeof formData !== "undefined" && formData ? formData : (formState && formState.adminCreateMember) || {}; %>
    <%- include("../partials/flash") %>

    <div class="mb-10 flex flex-col gap-4 rounded-4xl border border-slate-200 bg-white p-8 shadow-sm md:flex-row md:items-center md:justify-between">
      <div>
        <h1 class="text-3xl font-bold text-slate-900">Admin Dashboard</h1>
        <p class="mt-2 text-slate-600">Approve registrations, manage members, control profile visibility, and publish notices/events.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="/admin/settings" class="rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700">Site Settings</a>
        <form action="/auth/logout" method="post">
          <button type="submit" class="rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700">Logout</button>
        </form>
      </div>
    </div>

    <div class="mb-12 grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-4">
      <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm"><div class="text-sm font-semibold uppercase tracking-wide text-slate-500">Total Members</div><div class="mt-3 text-4xl font-extrabold text-slate-900"><%= summary.totalMembers %></div></article>
      <a href="/admin/members/pending" class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5"><div class="text-sm font-semibold uppercase tracking-wide text-slate-500">Pending Members</div><div class="mt-3 text-4xl font-extrabold text-amber-600"><%= summary.pendingMembers %></div></a>
      <a href="/admin/members/approved" class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5"><div class="text-sm font-semibold uppercase tracking-wide text-slate-500">Approved Members</div><div class="mt-3 text-4xl font-extrabold text-emerald-600"><%= summary.approvedMembers %></div></a>
      <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm"><div class="text-sm font-semibold uppercase tracking-wide text-slate-500">Leadership Members</div><div class="mt-3 text-4xl font-extrabold text-primary"><%= summary.leadershipMembers %></div></article>
    </div>

    <div class="mb-12 grid grid-cols-1 gap-8 lg:grid-cols-2">
      <section class="rounded-4xl border border-slate-200 bg-white p-8 shadow-sm">
        <h2 class="mb-6 text-2xl font-bold text-slate-900">Pending Approvals</h2>
        <div class="space-y-4">
          <% if (!pendingMembers.length) { %><div class="rounded-3xl border border-slate-200 bg-slate-50 px-5 py-4 text-sm text-slate-600">No pending registrations.</div><% } %>
          <% pendingMembers.forEach((member) => { %>
            <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
              <div class="mb-3 text-lg font-bold text-slate-900"><%= member.full_name %></div>
              <div class="mb-4 text-sm text-slate-600"><%= member.email %> | <%= member.phone %> | <%= member.role %></div>
              <div class="flex flex-col gap-3 md:flex-row">
                <form action="/admin/members/<%= member.id %>/approve" method="post" class="flex flex-1 gap-3">
                  <button type="submit" class="rounded-xl bg-emerald-600 px-4 py-2 text-sm font-semibold text-white">Approve</button>
                </form>
                <form action="/admin/members/<%= member.id %>/reject" method="post">
                  <button type="submit" class="rounded-xl bg-red-600 px-4 py-2 text-sm font-semibold text-white">Reject</button>
                </form>
                <a href="/admin/members/<%= member.id %>" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700">View</a>
                <a href="/admin/members/<%= member.id %>/edit" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700">Edit</a>
              </div>
            </div>
          <% }) %>
        </div>
      </section>

      <section class="rounded-4xl border border-slate-200 bg-white p-8 shadow-sm">
        <h2 class="mb-6 text-2xl font-bold text-slate-900">Add Member</h2>
        <form action="/admin/members" method="post" enctype="multipart/form-data" class="grid grid-cols-1 gap-4 md:grid-cols-2" data-validate-popup>
          <input name="full_name" value="<%= createMemberValues.full_name || '' %>" required placeholder="Full name" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900" />
          <input name="email" value="<%= createMemberValues.email || '' %>" required type="email" placeholder="Email" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900" />
          <input name="phone" value="<%= createMemberValues.phone || '' %>" placeholder="Phone" inputmode="numeric" data-validation-label="mobile number" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900" />
          <input name="profession" value="<%= createMemberValues.profession || '' %>" placeholder="Profession" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900" />
          <input name="city" value="<%= createMemberValues.city || '' %>" placeholder="City" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900" />
          <div class="md:col-span-2">
            <label for="dashboard-photo" class="mb-2 block text-sm font-semibold text-slate-700">Member Photo</label>
            <input id="dashboard-photo" name="photo" type="file" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 file:mr-4 file:rounded-full file:border-0 file:bg-primary file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white" />
            <p class="mt-2 text-xs text-slate-500">Optional. JPG, PNG, or WEBP up to 2 MB.</p>
          </div>
          <select name="role" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900"><% memberRoles.forEach((role) => { %><option <%= (createMemberValues.role || 'General Member') === role ? 'selected' : '' %>><%= role %></option><% }) %></select>
          <select name="membership_status" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900">
            <option value="approved" <%= (createMemberValues.membership_status || 'approved') === 'approved' ? 'selected' : '' %>>Approved</option>
            <option value="pending" <%= createMemberValues.membership_status === 'pending' ? 'selected' : '' %>>Pending</option>
            <option value="rejected" <%= createMemberValues.membership_status === 'rejected' ? 'selected' : '' %>>Rejected</option>
          </select>
          <div class="rounded-xl border border-slate-200 bg-slate-100 px-4 py-3 text-sm text-slate-500">Member ID will be generated automatically when a member is approved.</div>
          <input name="password" required type="password" placeholder="Password" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900 md:col-span-2" />
          <label class="flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" name="show_in_directory" <%= createMemberValues.show_in_directory ? 'checked' : '' %> /> Show in directory</label>
          <label class="flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" name="is_important_member" <%= createMemberValues.is_important_member ? 'checked' : '' %> /> Mark important member</label>
          <label class="flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" name="show_city_in_directory" <%= typeof createMemberValues.show_city_in_directory === 'undefined' || createMemberValues.show_city_in_directory ? 'checked' : '' %> /> Show city</label>
          <label class="flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" name="show_profession_in_directory" <%= typeof createMemberValues.show_profession_in_directory === 'undefined' || createMemberValues.show_profession_in_directory ? 'checked' : '' %> /> Show profession</label>
          <label class="flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" name="show_photo_in_directory" <%= typeof createMemberValues.show_photo_in_directory === 'undefined' || createMemberValues.show_photo_in_directory ? 'checked' : '' %> /> Show photo</label>
          <label class="flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" name="show_mobile_in_directory" <%= createMemberValues.show_mobile_in_directory ? 'checked' : '' %> /> Show mobile</label>
          <label class="flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" name="show_email_in_directory" <%= createMemberValues.show_email_in_directory ? 'checked' : '' %> /> Show email</label>
          <button type="submit" class="md:col-span-2 rounded-2xl bg-primary px-6 py-4 text-base font-semibold text-white">Create Member</button>
        </form>
      </section>
    </div>

    <div class="mb-12 grid grid-cols-1 gap-8 lg:grid-cols-2">
      <section class="rounded-4xl border border-slate-200 bg-white p-8 shadow-sm">
        <h2 class="mb-6 text-2xl font-bold text-slate-900">Notice & Event Manager</h2>
        <form action="/admin/notices" method="post" class="grid grid-cols-1 gap-4">
          <input name="title" required placeholder="Title" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900" />
          <textarea name="content" placeholder="Notice content" class="min-h-[120px] rounded-xl border-slate-200 bg-slate-50 text-slate-900"></textarea>
          <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
            <select name="type" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900"><option value="notice">Notice</option><option value="event">Event</option></select>
            <input name="event_date" type="date" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900" />
            <input name="expiry_date" type="date" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900" />
          </div>
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <input name="publish_date" type="date" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900" />
            <input name="sort_order" type="number" min="0" value="0" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900" />
          </div>
          <label class="flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" name="is_published" checked /> Publish immediately</label>
          <button type="submit" class="rounded-2xl bg-primary px-6 py-4 text-base font-semibold text-white">Save Notice</button>
        </form>
      </section>

      <section class="rounded-4xl border border-slate-200 bg-white p-8 shadow-sm">
        <h2 class="mb-6 text-2xl font-bold text-slate-900">Current Notices</h2>
        <div class="space-y-4">
          <% if (!notices.length) { %><div class="rounded-3xl border border-slate-200 bg-slate-50 px-5 py-4 text-sm text-slate-600">No notices or events have been added yet.</div><% } %>
          <% notices.forEach((notice) => { %>
            <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
              <div class="mb-2 text-lg font-bold text-slate-900"><%= notice.title %></div>
              <div class="mb-4 text-sm text-slate-500"><%= notice.type %></div>
              <div class="flex gap-3">
                <a href="/admin/notices/<%= notice.id %>/edit" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700">Edit</a>
                <form action="/admin/notices/<%= notice.id %>/delete" method="post"><button type="submit" class="rounded-xl bg-red-600 px-4 py-2 text-sm font-semibold text-white">Delete</button></form>
              </div>
            </div>
          <% }) %>
        </div>
      </section>
    </div>

    <section class="rounded-4xl border border-slate-200 bg-white p-8 shadow-sm">
      <h2 class="mb-6 text-2xl font-bold text-slate-900">All Members</h2>
      <div class="overflow-x-auto">
        <table class="min-w-full text-left text-sm">
          <thead><tr class="border-b border-slate-200 text-slate-500"><th class="px-3 py-3">Name</th><th class="px-3 py-3">Role</th><th class="px-3 py-3">Status</th><th class="px-3 py-3">Email</th><th class="px-3 py-3">Actions</th></tr></thead>
          <tbody>
            <% members.forEach((member) => { %>
              <tr class="border-b border-slate-100">
                <td class="px-3 py-3 font-medium text-slate-900"><%= member.full_name %></td>
                <td class="px-3 py-3"><%= member.role %></td>
                <td class="px-3 py-3"><%= member.membership_status %></td>
                <td class="px-3 py-3"><%= member.email %></td>
                <td class="px-3 py-3">
                  <div class="flex flex-wrap gap-2">
                    <a href="/admin/members/<%= member.id %>/edit" class="rounded-xl border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700">Edit</a>
                    <form action="/admin/members/<%= member.id %>/delete" method="post"><button type="submit" class="rounded-xl bg-red-600 px-3 py-2 text-xs font-semibold text-white">Delete</button></form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </section>
</main>

<%- include("../partials/footer") %>
<%- include("../partials/scripts") %>
