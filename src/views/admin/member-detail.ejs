<%- include("../partials/head") %>
<%- include("../partials/header") %>

<main class="min-h-screen bg-slate-50 px-4 pt-28">
  <section class="mx-auto max-w-6xl py-16 sm:px-6 lg:px-8">
    <%- include("../partials/flash") %>

    <div class="mb-8 flex flex-col gap-4 rounded-4xl border border-slate-200 bg-white p-8 shadow-sm md:flex-row md:items-center md:justify-between">
      <div>
        <h1 class="text-3xl font-bold text-slate-900"><%= member.full_name %></h1>
        <p class="mt-2 text-slate-600">Review the full member record before approval, rejection, or edits.</p>
      </div>
      <a href="/admin/dashboard" class="rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700">Back to Dashboard</a>
    </div>

    <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
      <section class="rounded-4xl border border-slate-200 bg-white p-8 shadow-sm lg:col-span-2">
        <h2 class="mb-6 text-2xl font-bold text-slate-900">Member Information</h2>
        <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
          <div><div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Full Name</div><div class="mt-1 text-slate-900"><%= member.full_name %></div></div>
          <div><div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Role</div><div class="mt-1 text-slate-900"><%= member.role %></div></div>
          <div><div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Email</div><div class="mt-1 text-slate-900"><%= member.email %></div></div>
          <div><div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Phone</div><div class="mt-1 text-slate-900"><%= member.phone || 'Not provided' %></div></div>
          <div><div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Profession</div><div class="mt-1 text-slate-900"><%= member.profession || 'Not provided' %></div></div>
          <div><div class="text-xs font-semibold uppercase tracking-wide text-slate-500">City</div><div class="mt-1 text-slate-900"><%= member.city || 'Not provided' %></div></div>
          <div><div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Blood Group</div><div class="mt-1 text-slate-900"><%= member.blood_group || 'Not provided' %></div></div>
          <div><div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Children Count</div><div class="mt-1 text-slate-900"><%= member.children_count ?? 'Not provided' %></div></div>
          <div><div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Status</div><div class="mt-1 text-slate-900"><%= member.membership_status %></div></div>
          <div><div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Member ID</div><div class="mt-1 text-slate-900"><%= member.member_id || 'Not assigned yet' %></div></div>
          <div><div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Approval Date</div><div class="mt-1 text-slate-900"><%= member.approval_date ? new Date(member.approval_date).toLocaleDateString('en-IN') : 'Not approved yet' %></div></div>
          <div><div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Approved By Admin</div><div class="mt-1 text-slate-900"><%= member.approved_by_admin ? 'Yes' : 'No' %></div></div>
          <div class="md:col-span-2"><div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Address</div><div class="mt-1 text-slate-900"><%= member.address || 'Not provided' %></div></div>
          <div class="md:col-span-2"><div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Admin Notes</div><div class="mt-1 text-slate-900"><%= member.admin_notes || 'No admin notes yet' %></div></div>
        </div>
      </section>

      <aside class="space-y-6">
        <section class="rounded-4xl border border-slate-200 bg-white p-8 shadow-sm">
          <h2 class="mb-5 text-xl font-bold text-slate-900">Actions</h2>
          <div class="space-y-3">
            <% if (member.membership_status !== 'approved') { %>
              <form action="/admin/members/<%= member.id %>/approve" method="post">
                <button type="submit" class="w-full rounded-2xl bg-emerald-600 px-6 py-4 text-base font-semibold text-white">Approve Member</button>
              </form>
            <% } %>
            <% if (member.membership_status !== 'rejected') { %>
              <form action="/admin/members/<%= member.id %>/reject" method="post">
                <button type="submit" class="w-full rounded-2xl bg-red-600 px-6 py-4 text-base font-semibold text-white">Reject Member</button>
              </form>
            <% } %>
            <a href="/admin/members/<%= member.id %>/edit" class="block w-full rounded-2xl border border-slate-300 px-6 py-4 text-center text-base font-semibold text-slate-700">Edit Member</a>
          </div>
        </section>

        <section class="rounded-4xl border border-slate-200 bg-white p-8 shadow-sm">
          <h2 class="mb-5 text-xl font-bold text-slate-900">Visibility</h2>
          <div class="space-y-2 text-sm text-slate-600">
            <div>Directory: <strong><%= member.show_in_directory ? 'Visible' : 'Hidden' %></strong></div>
            <div>Mobile: <strong><%= member.show_mobile_in_directory ? 'Visible' : 'Hidden' %></strong></div>
            <div>Email: <strong><%= member.show_email_in_directory ? 'Visible' : 'Hidden' %></strong></div>
            <div>City: <strong><%= member.show_city_in_directory ? 'Visible' : 'Hidden' %></strong></div>
            <div>Profession: <strong><%= member.show_profession_in_directory ? 'Visible' : 'Hidden' %></strong></div>
            <div>Photo: <strong><%= member.show_photo_in_directory ? 'Visible' : 'Hidden' %></strong></div>
          </div>
        </section>
      </aside>
    </div>
  </section>
</main>

<%- include("../partials/footer") %>
<%- include("../partials/scripts") %>
