<%- include("../partials/head") %>
<%- include("../partials/header") %>

<main class="min-h-screen bg-slate-50 px-4 pt-28">
  <section class="mx-auto max-w-7xl py-16 sm:px-6 lg:px-8">
    <%- include("../partials/flash") %>

    <div class="mb-8 flex flex-col gap-4 rounded-4xl border border-slate-200 bg-white p-8 shadow-sm md:flex-row md:items-center md:justify-between">
      <div>
        <h1 class="text-3xl font-bold text-slate-900"><%= heading %></h1>
        <p class="mt-2 text-slate-600"><%= description %></p>
      </div>
      <a href="/admin/dashboard" class="rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700">Back to Dashboard</a>
    </div>

    <div class="rounded-4xl border border-slate-200 bg-white p-8 shadow-sm">
      <div class="space-y-4">
        <% if (!members.length) { %>
          <div class="rounded-3xl border border-slate-200 bg-slate-50 px-5 py-4 text-sm text-slate-600">No members found in this status.</div>
        <% } %>
        <% members.forEach((member) => { %>
          <article class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
            <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
              <div>
                <h2 class="text-xl font-bold text-slate-900"><%= member.full_name %></h2>
                <div class="mt-2 text-sm text-slate-600"><%= member.email %> | <%= member.phone || 'No phone' %> | <%= member.role %></div>
                <div class="mt-2 text-sm text-slate-500">Status: <%= member.membership_status %><% if (member.member_id) { %> | Member ID: <%= member.member_id %><% } %></div>
              </div>
              <div class="flex flex-wrap gap-3">
                <a href="/admin/members/<%= member.id %>" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700">View</a>
                <a href="/admin/members/<%= member.id %>/edit" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700">Edit</a>
                <% if (memberStatus === "pending") { %>
                  <form action="/admin/members/<%= member.id %>/approve" method="post">
                    <button type="submit" class="rounded-xl bg-emerald-600 px-4 py-2 text-sm font-semibold text-white">Approve</button>
                  </form>
                  <form action="/admin/members/<%= member.id %>/reject" method="post">
                    <button type="submit" class="rounded-xl bg-red-600 px-4 py-2 text-sm font-semibold text-white">Reject</button>
                  </form>
                <% } %>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    </div>
  </section>
</main>

<%- include("../partials/footer") %>
<%- include("../partials/scripts") %>
