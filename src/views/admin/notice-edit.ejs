<%- include("../partials/head") %>
<%- include("../partials/header") %>

<main class="min-h-screen bg-slate-50 px-4 pt-28">
  <section class="mx-auto max-w-4xl py-16">
    <div class="mb-6"><a href="/admin" class="text-sm font-semibold text-primary">Back to Dashboard</a></div>
    <div class="rounded-4xl border border-slate-200 bg-white p-8 shadow-sm">
      <h1 class="mb-6 text-3xl font-bold text-slate-900">Edit Notice</h1>
      <form action="/admin/notices/<%= notice._id %>/edit" method="post" class="grid grid-cols-1 gap-4">
        <input name="title" value="<%= notice.title %>" required placeholder="Title" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900" />
        <textarea name="content" class="min-h-[140px] rounded-xl border-slate-200 bg-slate-50 text-slate-900" placeholder="Content"><%= notice.content || '' %></textarea>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
          <select name="type" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900"><option value="notice" <%= notice.type === 'notice' ? 'selected' : '' %>>Notice</option><option value="event" <%= notice.type === 'event' ? 'selected' : '' %>>Event</option></select>
          <input name="event_date" type="date" value="<%= notice.event_date ? new Date(notice.event_date).toISOString().split('T')[0] : '' %>" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900" />
          <input name="expiry_date" type="date" value="<%= notice.expiry_date ? new Date(notice.expiry_date).toISOString().split('T')[0] : '' %>" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900" />
        </div>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          <input name="publish_date" type="date" value="<%= notice.publish_date ? new Date(notice.publish_date).toISOString().split('T')[0] : '' %>" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900" />
          <input name="sort_order" type="number" min="0" value="<%= notice.sort_order || 0 %>" class="rounded-xl border-slate-200 bg-slate-50 text-slate-900" />
        </div>
        <label class="flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" name="is_published" <%= notice.is_published ? 'checked' : '' %> /> Published</label>
        <button type="submit" class="rounded-2xl bg-primary px-6 py-4 text-base font-semibold text-white">Save Notice</button>
      </form>
    </div>
  </section>
</main>

<%- include("../partials/footer") %>
<%- include("../partials/scripts") %>
