<%- include("../partials/head") %>
<%- include("../partials/header") %>

<main class="min-h-screen bg-slate-50 px-4 pt-28">
  <section class="mx-auto max-w-md py-20">
    <div class="rounded-4xl border border-slate-200 bg-white p-8 shadow-sm">
      <h1 class="mb-3 text-3xl font-bold text-slate-900">Member Login</h1>
      <p class="mb-8 text-slate-600">Approved members can sign in here to update their profile.</p>
      <% if (typeof errorMessage !== "undefined" && errorMessage) { %><div class="mb-6 rounded-3xl border border-red-200 bg-red-50 px-5 py-4 text-sm text-red-800"><%= errorMessage %></div><% } %>
      <form action="/member/login" method="post" class="space-y-5">
        <input name="email" type="email" required placeholder="Email" class="w-full rounded-xl border-slate-200 bg-slate-50 text-slate-900" />
        <input name="password" type="password" required placeholder="Password" class="w-full rounded-xl border-slate-200 bg-slate-50 text-slate-900" />
        <button type="submit" class="w-full rounded-2xl bg-primary px-6 py-4 text-base font-semibold text-white">Sign In</button>
      </form>
    </div>
  </section>
</main>

<%- include("../partials/footer") %>
<%- include("../partials/scripts") %>
