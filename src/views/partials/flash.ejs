<% if (typeof flash !== "undefined" && flash && flash.message) { %>
  <div class="mb-8 rounded-3xl border px-6 py-4 text-sm font-medium <%= flash.type === 'error' ? 'border-red-200 bg-red-50 text-red-800' : 'border-emerald-200 bg-emerald-50 text-emerald-800' %>" data-popup-message="<%= flash.message %>">
    <%= flash.message %>
  </div>
<% } %>
