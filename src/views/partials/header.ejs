<header class="fixed inset-x-0 top-0 z-50 border-b border-slate-200/60 bg-white/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-3">
      <img src="<%= site.logoPath %>" alt="<%= site.title %> logo" class="h-11 w-11 rounded-xl object-contain" />
      <div>
        <div class="text-base font-extrabold tracking-tight text-slate-900 sm:text-lg"><%= site.title %></div>
        <div class="hidden text-xs font-medium text-slate-500 sm:block">Professional community for engineers in Jabalpur</div>
      </div>
    </a>

    <button type="button" class="inline-flex rounded-full border border-slate-200 p-2 text-slate-700 md:hidden" data-mobile-menu-toggle aria-label="Toggle navigation">
      <i data-lucide="menu" class="h-5 w-5"></i>
    </button>

    <%- include("./navbar") %>
  </div>

  <div class="hidden border-t border-slate-200 bg-white md:hidden" data-mobile-menu>
    <div class="mx-auto max-w-7xl space-y-2 px-4 py-4 sm:px-6">
      <% site.primaryNav.forEach((link) => { %>
        <a href="<%= link.href %>" class="block rounded-2xl px-4 py-3 text-sm font-semibold <%= page.path === link.href ? 'bg-primary/10 text-primary' : 'text-slate-700 hover:bg-slate-100' %>"><%= link.label %></a>
      <% }) %>
      <a href="/member/login" class="block rounded-2xl px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-100">Member Login</a>
      <a href="/auth/login" class="block rounded-2xl px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-100">Admin Login</a>
      <a href="/register" class="block rounded-2xl bg-primary px-4 py-3 text-center text-sm font-semibold text-white">Join Now</a>
    </div>
  </div>
</header>
