<nav class="hidden items-center gap-2 md:flex">
  <% site.primaryNav.forEach((link) => { %>
    <a href="<%= link.href %>" class="rounded-full px-4 py-2 text-sm font-semibold transition <%= page.path === link.href ? 'bg-primary/5 text-primary' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900' %>"><%= link.label %></a>
  <% }) %>
  <% if (!currentUser) { %>
    <a href="/auth/login" class="rounded-full px-4 py-2 text-sm font-semibold text-slate-600 transition hover:bg-slate-100 hover:text-slate-900">Login</a>
  <% } else { %>
    <a href="<%= isAdmin ? '/admin/dashboard' : '/member/dashboard' %>" class="rounded-full px-4 py-2 text-sm font-semibold text-slate-600 transition hover:bg-slate-100 hover:text-slate-900">Dashboard</a>
    <form action="/auth/logout" method="post">
      <button type="submit" class="rounded-full px-4 py-2 text-sm font-semibold text-slate-600 transition hover:bg-slate-100 hover:text-slate-900">Logout</button>
    </form>
  <% } %>
  <a href="/register" class="ml-2 inline-flex min-w-[120px] items-center justify-center whitespace-nowrap rounded-full bg-primary px-6 py-3 text-sm font-semibold leading-none text-white shadow-primary-soft transition duration-200 hover:-translate-y-0.5 hover:bg-blue-700">Join Now</a>
</nav>
