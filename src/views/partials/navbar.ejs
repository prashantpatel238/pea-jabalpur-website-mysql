  <% }) %>
  <a href="/member/login" class="rounded-full px-4 py-2 text-sm font-semibold text-slate-600 transition hover:bg-slate-100 hover:text-slate-900">Member Login</a>
  <a href="/admin/login" class="rounded-full px-4 py-2 text-sm font-semibold text-slate-600 transition hover:bg-slate-100 hover:text-slate-900">Admin</a>
  <a href="/register" class="ml-2 inline-flex items-center rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-white shadow-primary-soft transition hover:-translate-y-0.5 hover:bg-blue-700">Join Now</a>
