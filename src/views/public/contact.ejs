<%- include("../partials/head") %>
<%- include("../partials/header") %>

<main>
  <section class="relative flex min-h-[50vh] items-center overflow-hidden pt-20">
    <div class="absolute inset-0 z-0">
      <img src="/assets/images/contact-hero.jpg" alt="Modern professional office" class="h-full w-full object-cover object-center" />
      <div class="hero-overlay"></div>
      <div class="hero-gradient"></div>
    </div>
    <div class="relative z-10 mx-auto w-full max-w-7xl px-4 py-20 text-center sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h1 class="mb-6 text-white">Get in <span class="bg-gradient-to-r from-blue-400 to-secondary bg-clip-text text-transparent">Touch</span></h1>
        <p class="text-lg leading-relaxed text-slate-300 md:text-xl">Have questions about membership, events, or our association? We're here to help. Reach out to us today.</p>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <% if (typeof formSubmitted !== "undefined" && formSubmitted) { %>
        <div class="mb-8 rounded-3xl border border-emerald-200 bg-emerald-50 px-6 py-4 text-sm font-medium text-emerald-800">
          Your message has been captured as a placeholder submission. TODO: connect this form to the future backend workflow.
        </div>
      <% } %>
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
        <div class="space-y-8 lg:col-span-5">
          <div>
            <h2 class="mb-8 text-3xl font-bold text-slate-900">Contact Information</h2>
            <div class="space-y-8">
              <div class="flex items-start gap-6">
                <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-slate-100 bg-white text-primary shadow-sm"><i data-lucide="map-pin" class="h-6 w-6"></i></div>
                <div>
                  <h3 class="mb-2 text-lg font-bold text-slate-900">Office Address</h3>
                  <p class="text-slate-600"><%= site.contact.addressLines.join(", ") %></p>
                </div>
              </div>
              <div class="flex items-start gap-6">
                <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-slate-100 bg-white text-primary shadow-sm"><i data-lucide="phone" class="h-6 w-6"></i></div>
                <div>
                  <h3 class="mb-2 text-lg font-bold text-slate-900">Phone &amp; WhatsApp</h3>
                  <p class="mb-3 font-medium text-slate-600"><%= site.contact.phone %></p>
                  <a href="https://wa.me/<%= site.contact.whatsapp %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-xl bg-green-50 px-4 py-2 text-sm font-bold text-green-600 transition hover:bg-green-100 hover:text-green-700">Chat on WhatsApp</a>
                </div>
              </div>
              <div class="flex items-start gap-6">
                <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-slate-100 bg-white text-primary shadow-sm"><i data-lucide="mail" class="h-6 w-6"></i></div>
                <div>
                  <h3 class="mb-2 text-lg font-bold text-slate-900">Email Address</h3>
                  <a href="mailto:<%= site.contact.email %>" class="font-medium text-primary hover:underline"><%= site.contact.email %></a>
                  <p class="mt-2 text-sm text-slate-500">We aim to reply within 24 hours</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="lg:col-span-7">
          <div class="rounded-[2rem] border border-slate-100 bg-white p-8 shadow-xl shadow-slate-200/50 md:p-12">
            <h2 class="mb-8 text-3xl font-bold text-slate-900">Send us a Message</h2>
            <form action="/contact" method="post" class="space-y-6">
              <!-- TODO: Replace with validated mailer or persistence layer during backend integration. -->
              <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                <div class="space-y-3">
                  <label for="name" class="text-sm font-semibold text-slate-700">Full Name</label>
                  <input id="name" name="name" required class="w-full rounded-xl border-slate-200 bg-slate-50 text-slate-900" placeholder="John Doe" />
                </div>
                <div class="space-y-3">
                  <label for="email" class="text-sm font-semibold text-slate-700">Email Address</label>
                  <input id="email" name="email" type="email" required class="w-full rounded-xl border-slate-200 bg-slate-50 text-slate-900" placeholder="john@example.com" />
                </div>
              </div>
              <div class="space-y-3">
                <label for="subject" class="text-sm font-semibold text-slate-700">Subject</label>
                <input id="subject" name="subject" required class="w-full rounded-xl border-slate-200 bg-slate-50 text-slate-900" placeholder="How can we help you?" />
              </div>
              <div class="space-y-3">
                <label for="message" class="text-sm font-semibold text-slate-700">Message</label>
                <textarea id="message" name="message" required class="min-h-[160px] w-full rounded-xl border-slate-200 bg-slate-50 p-4 text-slate-900" placeholder="Write your message here..."></textarea>
              </div>
              <button type="submit" class="inline-flex h-14 w-full items-center justify-center rounded-full bg-primary px-8 text-base font-semibold text-white shadow-primary-soft transition hover:-translate-y-1 hover:bg-blue-700 md:w-auto">Send Message</button>
            </form>
          </div>
        </div>
      </div>

      <div class="mt-16">
        <h2 class="mb-8 text-center text-3xl font-bold text-slate-900">Find Us on the Map</h2>
        <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-lg">
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3667.3947!2d79.9!3d23.1815!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjPCsDEwJzUzLjQiTiA3OcKwNTQnMDAuMCJF!5e0!3m2!1sen!2sin!4v1234567890" width="100%" height="450" style="border:0;" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="PEA Jabalpur Location"></iframe>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include("../partials/footer") %>
<%- include("../partials/scripts") %>
