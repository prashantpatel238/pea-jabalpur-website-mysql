<%- include("../partials/head") %>
<%- include("../partials/header") %>

<main class="min-h-screen bg-slate-50 pt-28">
  <section class="mx-auto max-w-7xl px-4 pb-24 sm:px-6 lg:px-8">
    <%- include("../partials/flash") %>
    <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <h1 class="mb-2 text-3xl font-bold text-slate-900 md:text-4xl">Member Directory</h1>
        <p class="text-slate-600">All approved members who are allowed to appear in the public directory are listed here.</p>
      </div>
    </div>

    <form action="/member-directory" method="get" class="mb-10 flex flex-col gap-4 rounded-3xl border border-slate-200 bg-white p-4 shadow-sm lg:flex-row lg:items-end">
      <div class="w-full lg:flex-1">
        <label for="search" class="mb-2 block text-sm font-semibold text-slate-700">Search by name</label>
        <input id="search" name="search" value="<%= filters.search %>" placeholder="Search members..." class="w-full rounded-2xl border-slate-200 bg-slate-50 text-slate-900" />
      </div>
      <div class="w-full lg:w-64">
        <label for="city" class="mb-2 block text-sm font-semibold text-slate-700">City</label>
        <select id="city" name="city" class="w-full rounded-2xl border-slate-200 bg-slate-50 text-slate-900">
          <option value="">All cities</option>
          <% filterOptions.cities.forEach((option) => { %>
            <option value="<%= option %>" <%= filters.city === option ? 'selected' : '' %>><%= option %></option>
          <% }) %>
        </select>
      </div>
      <div class="w-full lg:w-64">
        <label for="profession" class="mb-2 block text-sm font-semibold text-slate-700">Profession</label>
        <select id="profession" name="profession" class="w-full rounded-2xl border-slate-200 bg-slate-50 text-slate-900">
          <option value="">All professions</option>
          <% filterOptions.professions.forEach((option) => { %>
            <option value="<%= option %>" <%= filters.profession === option ? 'selected' : '' %>><%= option %></option>
          <% }) %>
        </select>
      </div>
      <div class="flex gap-3">
        <button type="submit" class="inline-flex h-12 items-center justify-center rounded-full bg-primary px-6 text-sm font-semibold text-white">Filter</button>
        <a href="/member-directory" class="inline-flex h-12 items-center justify-center rounded-full border border-slate-300 px-6 text-sm font-semibold text-slate-700">Reset</a>
      </div>
    </form>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      <% if (!members.length) { %>
        <div class="col-span-full rounded-3xl border border-slate-200 bg-white p-8 text-slate-600 shadow-sm">No approved directory members match the current filters.</div>
      <% } %>
      <% members.forEach((member) => { %>
        <article class="flex flex-col rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="mb-4 flex items-center gap-4 border-b border-slate-100 pb-4">
            <div class="flex h-16 w-16 items-center justify-center rounded-full bg-primary/10">
              <img src="<%= member.photo %>" alt="<%= member.full_name %>" class="h-12 w-12 rounded-full object-cover" />
            </div>
            <div class="min-w-0 flex-1">
              <h3 class="truncate text-lg font-bold text-slate-900"><%= member.full_name %></h3>
              <span class="mt-1 inline-block rounded-full border border-slate-200 bg-slate-50 px-2 py-0.5 text-xs text-slate-500"><%= member.role %></span>
            </div>
          </div>
          <div class="space-y-3 text-sm text-slate-600">
            <% if (member.profession) { %><div><%= member.profession %></div><% } %>
            <% if (member.city) { %><div><%= member.city %></div><% } %>
            <% if (member.email) { %><div><a href="mailto:<%= member.email %>" class="hover:text-primary"><%= member.email %></a></div><% } %>
            <% if (member.phone) { %><div><%= member.phone %></div><% } %>
          </div>
          <% if (member.member_id || member.join_date) { %>
            <div class="mt-6 border-t border-slate-100 pt-4 text-sm font-medium text-primary">
              <%= member.member_id ? `Member ID: ${member.member_id}` : '' %><%= member.member_id && member.join_date ? ' | ' : '' %><%= member.join_date ? `Joined: ${member.join_date}` : '' %>
            </div>
          <% } %>
        </article>
      <% }) %>
    </div>
  </section>
</main>

<%- include("../partials/footer") %>
<%- include("../partials/scripts") %>
