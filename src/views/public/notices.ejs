<%- include("../partials/head") %>
<%- include("../partials/header") %>

<main class="min-h-screen bg-slate-50 pt-28">
  <section class="mx-auto max-w-5xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="rounded-4xl border border-slate-200 bg-white p-10 shadow-sm">
      <h1 class="mb-4 text-3xl font-bold text-slate-900">Notice Board</h1>
      <p class="mb-8 text-lg text-slate-600">Browse updates by category so members can focus on special days, events, or official notices separately.</p>
      <div class="mb-10 flex flex-wrap gap-3">
        <% noticeCategories.forEach((category) => { %>
          <a
            href="/notices?<%= new URLSearchParams({ category: category.value }).toString() %>"
            class="<%= activeCategory === category.value ? 'bg-primary text-white border-primary shadow-sm' : 'border-slate-200 bg-slate-50 text-slate-700' %> inline-flex items-center gap-2 rounded-full border px-5 py-3 text-sm font-semibold transition hover:border-primary hover:text-primary"
          >
            <span><%= category.label %></span>
            <span class="<%= activeCategory === category.value ? 'bg-white/20 text-white' : 'bg-white text-slate-500' %> rounded-full px-2.5 py-0.5 text-xs font-bold"><%= category.count %></span>
          </a>
        <% }) %>
      </div>
      <div class="space-y-4">
        <% if (!notices.length) { %>
          <div class="rounded-3xl border border-slate-200 bg-slate-50 px-6 py-4 text-sm text-slate-700">No items are available in this section right now.</div>
        <% } %>
        <% notices.forEach((notice) => { %>
          <article class="rounded-3xl border border-slate-200 bg-slate-50 p-6">
            <div class="mb-4 flex flex-wrap items-start justify-between gap-4">
              <div class="flex flex-wrap items-center gap-3">
                <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-bold uppercase tracking-wide text-primary"><%= notice.type_label %></span>
                <% if (notice.type === 'event' && notice.event_date) { %>
                  <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700">Upcoming Event</span>
                <% } %>
                <% if ((notice.type === 'birthday' || notice.type === 'anniversary') && notice.event_date) { %>
                  <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-700">Special Day</span>
                <% } %>
              </div>
              <div class="grid gap-2 text-sm text-slate-500 sm:text-right">
                <% if (notice.publish_date) { %>
                  <div><span class="font-semibold text-slate-700">Published:</span> <%= new Date(notice.publish_date).toLocaleDateString("en-IN", { day: "2-digit", month: "short", year: "numeric" }) %></div>
                <% } %>
                <% if (notice.event_date) { %>
                  <div><span class="font-semibold text-slate-700"><%= notice.type === 'event' ? 'Event Date:' : (notice.type === 'birthday' || notice.type === 'anniversary' ? 'Celebration Date:' : 'Notice Date:') %></span> <%= new Date(notice.event_date).toLocaleDateString("en-IN", { day: "2-digit", month: "short", year: "numeric" }) %></div>
                <% } %>
                <% if (notice.expiry_date) { %>
                  <div><span class="font-semibold text-slate-700">Valid Until:</span> <%= new Date(notice.expiry_date).toLocaleDateString("en-IN", { day: "2-digit", month: "short", year: "numeric" }) %></div>
                <% } %>
              </div>
            </div>
            <h2 class="mb-2 text-xl font-bold text-slate-900"><%= notice.title %></h2>
            <p class="leading-7 text-slate-600"><%= notice.content %></p>
          </article>
        <% }) %>
      </div>
    </div>
  </section>
</main>

<%- include("../partials/footer") %>
<%- include("../partials/scripts") %>
