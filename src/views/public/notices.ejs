<%- include("../partials/head") %>
<%- include("../partials/header") %>

<main class="min-h-screen bg-slate-50 pt-28">
  <section class="mx-auto max-w-5xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="rounded-4xl border border-slate-200 bg-white p-10 shadow-sm">
      <h1 class="mb-4 text-3xl font-bold text-slate-900">Notice Board</h1>
      <p class="mb-10 text-lg text-slate-600">Members can view upcoming notices, events, birthdays, and anniversaries here.</p>
      <div class="space-y-4">
        <% if (!notices.length) { %>
          <div class="rounded-3xl border border-slate-200 bg-slate-50 px-6 py-4 text-sm text-slate-700">No current notices or upcoming celebrations are available.</div>
        <% } %>
        <% notices.forEach((notice) => { %>
          <article class="rounded-3xl border border-slate-200 bg-slate-50 p-6">
            <div class="mb-3 flex flex-wrap items-center gap-3">
              <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-bold uppercase tracking-wide text-primary"><%= notice.type %></span>
              <% if (notice.event_date) { %>
                <span class="text-sm text-slate-500"><%= new Date(notice.event_date).toLocaleDateString("en-IN", { day: "2-digit", month: "short", year: "numeric" }) %></span>
              <% } %>
            </div>
            <h2 class="mb-2 text-xl font-bold text-slate-900"><%= notice.title %></h2>
            <p class="text-slate-600"><%= notice.content %></p>
          </article>
        <% }) %>
      </div>
    </div>
  </section>
</main>

<%- include("../partials/footer") %>
<%- include("../partials/scripts") %>
