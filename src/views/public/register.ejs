<%- include("../partials/head") %>
<%- include("../partials/header") %>

<main class="min-h-screen bg-slate-50 px-4 py-12 pt-28 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-3xl">
    <% const values = typeof formData !== "undefined" && formData ? formData : (formState && formState.register) || {}; %>
    <%- include("../partials/flash") %>
    <% if (typeof formSubmitted !== "undefined" && formSubmitted) { %>
      <div class="mb-8 rounded-3xl border border-emerald-200 bg-emerald-50 px-6 py-4 text-sm text-emerald-800">
        Your registration has been submitted successfully and is pending admin approval. Your member ID will only be created after approval.
      </div>
    <% } %>
    <% if (typeof errorMessage !== "undefined" && errorMessage) { %>
      <div class="mb-8 rounded-3xl border border-red-200 bg-red-50 px-6 py-4 text-sm text-red-800" data-popup-message="<%= errorMessage %>">
        <%= errorMessage %>
      </div>
    <% } %>
    <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
      <div class="bg-primary px-8 py-10 text-center">
        <div class="mx-auto inline-flex rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-white/90">
          Membership Application
        </div>
        <h1 class="mt-4 text-3xl font-bold tracking-tight text-white sm:text-4xl">Join the Association</h1>
        <p class="mx-auto mt-3 max-w-2xl text-base leading-7 text-white/80">Become part of a professional engineering community focused on collaboration, leadership, and meaningful local impact.</p>
        <div class="mx-auto mt-6 inline-flex items-center rounded-2xl border border-white/15 bg-white/10 px-5 py-3 text-left shadow-[0_16px_36px_rgba(15,23,42,0.16)] backdrop-blur-sm">
          <div>
            <div class="text-lg font-semibold text-white">Join Now</div>
            <div class="text-sm text-white/75">Complete the form below to request membership approval</div>
          </div>
        </div>
      </div>

      <form action="/register" method="post" enctype="multipart/form-data" class="space-y-8 p-8" data-validate-popup>
        <div>
          <h2 class="mb-4 border-b border-slate-100 pb-2 text-lg font-semibold text-slate-900">Account Details</h2>
          <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            <div class="space-y-2">
              <label for="full_name" class="text-sm font-medium text-slate-700">Full Name *</label>
              <input id="full_name" name="full_name" value="<%= values.full_name || '' %>" required class="w-full rounded-xl border-slate-200 text-slate-900" placeholder="John Doe" />
            </div>
            <div class="space-y-2">
              <label for="email" class="text-sm font-medium text-slate-700">Email Address *</label>
              <input id="email" name="email" type="email" value="<%= values.email || '' %>" required class="w-full rounded-xl border-slate-200 text-slate-900" placeholder="john@example.com" />
            </div>
            <div class="space-y-2">
              <label for="phone" class="text-sm font-medium text-slate-700">Phone Number *</label>
              <input id="phone" name="phone" type="tel" value="<%= values.phone || '' %>" required inputmode="numeric" data-validation-label="mobile number" class="w-full rounded-xl border-slate-200 text-slate-900" placeholder="9876543210" />
            </div>
            <div class="space-y-2">
              <label for="profession" class="text-sm font-medium text-slate-700">Profession</label>
              <input id="profession" name="profession" value="<%= values.profession || '' %>" class="w-full rounded-xl border-slate-200 text-slate-900" placeholder="Civil Engineer" />
            </div>
            <div class="space-y-2">
              <label for="city" class="text-sm font-medium text-slate-700">City</label>
              <input id="city" name="city" value="<%= values.city || '' %>" class="w-full rounded-xl border-slate-200 text-slate-900" placeholder="Jabalpur" />
            </div>
            <div class="space-y-2">
              <label for="photo" class="text-sm font-medium text-slate-700">Profile Photo</label>
              <input id="photo" name="photo" type="file" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 file:mr-4 file:rounded-full file:border-0 file:bg-primary file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white" />
              <p class="text-xs text-slate-500">Optional. JPG, PNG, or WEBP up to 2 MB.</p>
            </div>
            <div class="space-y-2">
              <label for="role" class="text-sm font-medium text-slate-700">Role</label>
              <select id="role" name="role" class="w-full rounded-xl border-slate-200 text-slate-900">
                <option <%= (values.role || 'General Member') === 'General Member' ? 'selected' : '' %>>General Member</option>
                <option <%= values.role === 'Core Committee Member' ? 'selected' : '' %>>Core Committee Member</option>
                <option <%= values.role === 'Media Prabhari' ? 'selected' : '' %>>Media Prabhari</option>
                <option <%= values.role === 'Treasurer' ? 'selected' : '' %>>Treasurer</option>
                <option <%= values.role === 'Joint Secretary' ? 'selected' : '' %>>Joint Secretary</option>
                <option <%= values.role === 'Secretary' ? 'selected' : '' %>>Secretary</option>
                <option <%= values.role === 'Vice President' ? 'selected' : '' %>>Vice President</option>
                <option <%= values.role === 'President' ? 'selected' : '' %>>President</option>
              </select>
            </div>
            <div class="space-y-2">
              <label for="password" class="text-sm font-medium text-slate-700">Password *</label>
              <input id="password" name="password" type="password" required class="w-full rounded-xl border-slate-200 text-slate-900" placeholder="********" />
            </div>
            <div class="space-y-2">
              <label for="confirm_password" class="text-sm font-medium text-slate-700">Confirm Password *</label>
              <input id="confirm_password" name="confirm_password" type="password" required class="w-full rounded-xl border-slate-200 text-slate-900" placeholder="********" />
            </div>
          </div>
        </div>

        <div>
          <h2 class="mb-4 border-b border-slate-100 pb-2 text-lg font-semibold text-slate-900">Personal Details</h2>
          <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            <div class="space-y-2">
              <label for="gender" class="text-sm font-medium text-slate-700">Gender</label>
              <select id="gender" name="gender" class="w-full rounded-xl border-slate-200 text-slate-900">
                <option value="" <%= !values.gender ? 'selected' : '' %>>Select gender</option>
                <option value="male" <%= values.gender === 'male' ? 'selected' : '' %>>Male</option>
                <option value="female" <%= values.gender === 'female' ? 'selected' : '' %>>Female</option>
                <option value="other" <%= values.gender === 'other' ? 'selected' : '' %>>Other</option>
                <option value="prefer_not_to_say" <%= values.gender === 'prefer_not_to_say' ? 'selected' : '' %>>Prefer not to say</option>
              </select>
            </div>
            <div class="space-y-2">
              <label for="dob" class="text-sm font-medium text-slate-700">Date of Birth</label>
              <input id="dob" name="dob" type="date" value="<%= values.dob || '' %>" class="w-full rounded-xl border-slate-200 text-slate-900" />
            </div>
            <div class="space-y-2">
              <label for="blood_group" class="text-sm font-medium text-slate-700">Blood Group</label>
              <select id="blood_group" name="blood_group" class="w-full rounded-xl border-slate-200 text-slate-900">
                <% bloodGroupOptions.forEach((option) => { %>
                  <option value="<%= option %>" <%= (values.blood_group || '') === option ? 'selected' : '' %>><%= option || 'Select blood group' %></option>
                <% }) %>
              </select>
            </div>
            <div class="space-y-2">
              <label for="marital_status" class="text-sm font-medium text-slate-700">Marital Status</label>
              <select id="marital_status" name="marital_status" class="w-full rounded-xl border-slate-200 text-slate-900">
                <option value="" <%= !values.marital_status ? 'selected' : '' %>>Select status</option>
                <option value="single" <%= values.marital_status === 'single' ? 'selected' : '' %>>Single</option>
                <option value="married" <%= values.marital_status === 'married' ? 'selected' : '' %>>Married</option>
                <option value="divorced" <%= values.marital_status === 'divorced' ? 'selected' : '' %>>Divorced</option>
                <option value="widowed" <%= values.marital_status === 'widowed' ? 'selected' : '' %>>Widowed</option>
                <option value="prefer_not_to_say" <%= values.marital_status === 'prefer_not_to_say' ? 'selected' : '' %>>Prefer not to say</option>
              </select>
            </div>
            <div class="space-y-2" data-marriage-field>
              <label for="spouse_name" class="text-sm font-medium text-slate-700">Spouse Name</label>
              <input id="spouse_name" name="spouse_name" value="<%= values.spouse_name || '' %>" class="w-full rounded-xl border-slate-200 text-slate-900" />
            </div>
            <div class="space-y-2" data-marriage-field>
              <label for="marriage_date" class="text-sm font-medium text-slate-700">Marriage Date</label>
              <input id="marriage_date" name="marriage_date" type="date" value="<%= values.marriage_date || '' %>" class="w-full rounded-xl border-slate-200 text-slate-900" />
            </div>
            <div class="space-y-2" data-children-field>
              <label for="children_count" class="text-sm font-medium text-slate-700">Children Count</label>
              <input id="children_count" name="children_count" type="number" min="0" step="1" value="<%= values.children_count || values.children_count === 0 ? values.children_count : '' %>" class="w-full rounded-xl border-slate-200 text-slate-900" placeholder="0" />
            </div>
            <div class="space-y-2 md:col-span-2">
              <label for="address" class="text-sm font-medium text-slate-700">Address</label>
              <textarea id="address" name="address" class="min-h-[120px] w-full rounded-xl border-slate-200 text-slate-900"><%= values.address || '' %></textarea>
            </div>
          </div>
        </div>

        <div class="pt-4">
          <button type="submit" class="inline-flex w-full items-center justify-center rounded-2xl bg-primary px-6 py-4 text-center text-lg font-semibold tracking-tight text-white shadow-[0_18px_40px_rgba(37,99,235,0.22)] transition duration-200 hover:-translate-y-0.5 hover:bg-blue-700 hover:shadow-[0_22px_46px_rgba(37,99,235,0.28)]">
            <span class="flex flex-col items-center">
              <span>Join Now</span>
              <span class="text-sm font-medium text-white/80">Submit your membership application</span>
            </span>
          </button>
        </div>
      </form>

      <div class="border-t border-slate-200 bg-slate-50 px-8 py-6 text-center">
        <p class="text-sm text-slate-600">After admin approval, members can sign in and update their profile.</p>
      </div>
    </div>
  </div>
</main>

<%- include("../partials/footer") %>
<%- include("../partials/scripts") %>
<script>
  (() => {
    const maritalStatusInput = document.getElementById("marital_status");
    const marriageFields = Array.from(document.querySelectorAll("[data-marriage-field]"));
    const childrenFields = Array.from(document.querySelectorAll("[data-children-field]"));

    if (!maritalStatusInput || (!marriageFields.length && !childrenFields.length)) {
      return;
    }

    function clearFields(fields) {
      fields.forEach((field) => {
        field.querySelectorAll("input, select, textarea").forEach((input) => {
          input.value = "";
        });
      });
    }

    function updateMarriageFields() {
      const shouldShowMarriageFields = maritalStatusInput.value === "married";

      marriageFields.forEach((field) => {
        field.classList.toggle("hidden", !shouldShowMarriageFields);
      });

      childrenFields.forEach((field) => {
        field.classList.toggle("hidden", !shouldShowMarriageFields);
      });

      if (!shouldShowMarriageFields) {
        clearFields(marriageFields);
        clearFields(childrenFields);
      }
    }

    maritalStatusInput.addEventListener("change", updateMarriageFields);
    updateMarriageFields();
  })();
</script>
